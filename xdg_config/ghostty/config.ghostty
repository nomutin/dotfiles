# terminal
shell-integration = bash
term = xterm-256color

# appearance
theme = carbonfox
background-opacity = 0.9
cursor-style-blink = false
window-padding-x = 8
window-padding-y = 8

# feat
auto-update-channel = tip
confirm-close-surface = false
maximize = true
macos-titlebar-style = hidden
macos-icon = blueprint
keybind = ctrl+opt+enter=toggle_maximize

# font
# font-family = Cica
font-size = 12
font-thicken = true
font-feature = -dlii
font-feature = -calt
font-feature = -liga
