# Terminal
shell-integration = bash
term = xterm-256color

# Appearance
theme = carbonfox
background-opacity = 0.8
cursor-style-blink = false
window-padding-x = 8
window-padding-y = 8

# Feat
auto-update-channel = tip
confirm-close-surface = false
maximize = true
macos-titlebar-style = hidden
keybind = ctrl+opt+enter=toggle_maximize

# Font
font-family = "Monaco"
font-family = "PCMyungjo Regular"
font-size = 12
font-thicken = true
font-feature = -dlii
font-feature = -calt
font-feature = -liga
